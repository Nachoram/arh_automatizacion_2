    {
      "parameters": {
        "jsCode": "// Valor referencial de la UF para el cálculo de acciones legales \nconst VALOR_UF = 38000; \nconst UMBRAL_UF = 35 * VALOR_UF;\n\nconst nuevosItems = [];\n\nfor (const item of $input.all()) {\n  try {\n    // 1. Extraer y limpiar el JSON proveniente del AI Agent\n    let rawOutput = item.json.output;\n    const jsonString = rawOutput.replace(/```json|```/gi, '').trim();\n    const dataIA = JSON.parse(jsonString);\n\n    // 2. Lógica de Negocio: Cálculo de Tipo_Acción (> 35 UF) \n    const monto = parseFloat(dataIA.monto_reclamado) || 0;\n    const tipoAccion = monto > UMBRAL_UF ? \"Demanda Civil\" : \"Medida Prejudicial\";\n\n    // 3. Construir el objeto plano final (sin ID_Maestro) para Expedientes_Core \n    nuevosItems.push({\n      json: {\n        \"Folio_Banco\": Array.isArray(dataIA.folios_banco) ? dataIA.folios_banco.join(', ') : dataIA.folios_banco,\n        \"Banco_Cliente\": dataIA.banco_cliente,\n        \"RUT_Cliente\": dataIA.rut_cliente,\n        \"Monto_Reclamado\": monto,\n        \"Tipo_Acción\": tipoAccion,\n        \"Estado_Ley_21234\": \"Ingresado\",\n        \"Nombre_cliente\": dataIA.nombre_cliente,\n        \"Domicilio_cliente\": dataIA.domicilio_cliente || \"No especificado\",\n        \"Brief_IA\": dataIA.resumen_ia\n      }\n    });\n  } catch (error) {\n    nuevosItems.push({ json: { error: \"Error procesando datos de IA: \" + error.message } });\n  }\n}\n\nreturn nuevosItems;"
      },
